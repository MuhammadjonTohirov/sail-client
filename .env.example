# Backend API base URL. Inlined into the client bundle at BUILD time
# (must be set as a Docker build arg in Coolify, not only as a runtime env var).
NEXT_PUBLIC_API_URL=https://api.sail.uz

# Telegram Login Widget
# Get your bot username from @BotFather
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=sail2_bot

# Do not put server-only secrets here. Next.js client env examples should only contain NEXT_PUBLIC_* values.
